# ── Upstream Kapruka REST API ────────────────────────────────────────────────
KAPRUKA_API_BASE_URL=https://www.kapruka.com
KAPRUKA_API_KEY=your-internal-kapruka-api-key

# ── MCP server bind ──────────────────────────────────────────────────────────
# In production, bind to 127.0.0.1 and let Caddy front it on mcp.kapruka.com.
MCP_HOST=127.0.0.1
MCP_PORT=3200

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── HTTP defaults ────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30

# ── Free public tier rate limit (per client IP, fixed 60s window) ────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Comma-separated IPs we trust to set X-Real-IP / X-Forwarded-For.
# Leave default for Caddy on the same host. Add Cloudflare ranges if
# you ever put CF in front.
TRUSTED_PROXIES=127.0.0.1,::1

# ── MCP DNS-rebinding protection ─────────────────────────────────────────────
# The MCP SDK rejects requests whose Host/Origin header isn't in these lists.
# Add the public hostname(s) Caddy fronts.
PUBLIC_HOSTS=127.0.0.1:*,localhost:*,[::1]:*,mcp.kapruka.com
PUBLIC_ORIGINS=http://127.0.0.1:*,http://localhost:*,http://[::1]:*,https://mcp.kapruka.com
